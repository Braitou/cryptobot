# ============================================
# CryptoBot v0.1 — Configuration
# Copier ce fichier en .env et remplir les valeurs
# cp .env.example .env
# ============================================

# --- Binance ---
# Créer une clé API sur https://www.binance.com/en/my/settings/api-management
# IMPORTANT : permissions "Enable Spot Trading" UNIQUEMENT, pas de withdrawal
# IMPORTANT : activer l'IP whitelist
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here
BINANCE_TESTNET=true

# --- Trading ---
# Paires à trader (séparées par des virgules)
PAIRS=BTCUSDT,ETHUSDT,SOLUSDT,AVAXUSDT,LINKUSDT
# Intervalles de bougies
CANDLE_INTERVALS=1m,5m,15m
# Mode : "paper" (simulation) ou "live" (argent réel)
TRADING_MODE=paper
# Capital initial en USDT
INITIAL_CAPITAL=500.0

# --- Risk Management ---
MAX_POSITION_PCT=0.10
STOP_LOSS_ATR_MULT=1.5
TAKE_PROFIT_ATR_MULT=2.0
TRAILING_STOP_ATR_MULT=1.0
MAX_OPEN_POSITIONS=4
MAX_DAILY_LOSS_PCT=0.03
MAX_TOTAL_DRAWDOWN_PCT=0.15

# --- Anthropic (REQUIS — les agents IA utilisent Claude API) ---
# Créer une clé sur https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
AI_MODEL_FAST=claude-haiku-4-5-20251001
AI_MODEL_DEEP=claude-sonnet-4-6
AI_TEMPERATURE=0.3

# --- API Dashboard ---
API_HOST=0.0.0.0
API_PORT=8000
